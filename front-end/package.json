{
  "name": "mnss-nova-alianca-front-end",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "start:local": "ng serve --host 0.0.0.0 --port 4200 --configuration local --proxy-config proxy.conf.json",
    "start:online": "ng serve --host 0.0.0.0 --port 4200 --configuration online",
    "build": "ng build",
    "build:local": "ng build --configuration local",
    "build:online": "ng build --configuration online",
    "lint": "eslint \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"*.json\"",
    "test": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "dependencies": {
    "@angular/animations": "20.3.20",
    "@angular/common": "20.3.20",
    "@angular/compiler": "20.3.20",
    "@angular/core": "20.3.20",
    "@angular/forms": "20.3.20",
    "@angular/platform-browser": "20.3.20",
    "@angular/router": "20.3.20",
    "@angular/service-worker": "20.3.20",
    "@stomp/stompjs": "^7.3.0",
    "@types/sockjs-client": "^1.5.4",
    "rxjs": "^7.8.2",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.25",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.20",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "^6.0.0",
    "eslint": "^10.3.0",
    "jasmine-core": "^5.9.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1"
  }
}