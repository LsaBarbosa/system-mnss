SPRING_PROFILES_ACTIVE=local

# PostgreSQL
POSTGRES_DB=nova_alianca_local
POSTGRES_USER=nova_alianca
POSTGRES_PASSWORD=change_me

# RabbitMQ
RABBITMQ_DEFAULT_USER=nova_alianca
RABBITMQ_DEFAULT_PASS=change_me

# Redis
REDIS_PORT=6379

# Portas externas (a porta interna da API é sempre 8080)
LOCAL_API_PORT=8080
NGINX_HTTP_PORT=80

# JWT / Auth (mínimo 32 caracteres)
AUTH_TOKEN_SECRET=change_me_auth_token_secret_with_at_least_32_chars
AUTH_TOKEN_TTL=PT8H

# Admin inicial
MNSS_INITIAL_ADMIN_USERNAME=admin
MNSS_INITIAL_ADMIN_PASSWORD=change_me_admin_password
MNSS_INITIAL_ADMIN_EMAIL=admin@novaalianca.local

# Sincronização com a online
MNSS_ONLINE_URL=https://api.padarianovaalianca.com.br
MNSS_STORE_ID=nova-alianca-001
MNSS_STORE_SECRET=change_me_store_secret_with_at_least_32_chars

# Em produção manter true; em desenvolvimento local HTTP pode usar false
MNSS_SYNC_REQUIRE_HTTPS=true
