SPRING_PROFILES_ACTIVE=local

# PostgreSQL
POSTGRES_DB=nova_alianca_local
POSTGRES_USER=nova_alianca
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# RabbitMQ
RABBITMQ_DEFAULT_USER=nova_alianca
RABBITMQ_DEFAULT_PASS=REPLACE_WITH_SECURE_PASSWORD

# Redis
REDIS_PORT=6379

# Portas externas (a porta interna da API é sempre 8080)
LOCAL_API_PORT=8080
NGINX_HTTP_PORT=80

# JWT / Auth — mínimo 32 bytes: openssl rand -base64 32
AUTH_TOKEN_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET
AUTH_TOKEN_TTL=PT8H

# Admin inicial
MNSS_INITIAL_ADMIN_USERNAME=admin
MNSS_INITIAL_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
MNSS_INITIAL_ADMIN_EMAIL=admin@novaalianca.local

# Sincronização com a online
MNSS_ONLINE_URL=https://api.padarianovaalianca.com.br
MNSS_STORE_ID=nova-alianca-001
# Mínimo 32 bytes: openssl rand -hex 32
MNSS_STORE_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET

# Em produção manter true; em desenvolvimento local HTTP pode usar false
MNSS_SYNC_REQUIRE_HTTPS=true
