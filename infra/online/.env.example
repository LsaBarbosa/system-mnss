SPRING_PROFILES_ACTIVE=online

# ============================================================
# PostgreSQL online
# ============================================================
POSTGRES_DB=nova_alianca_online
POSTGRES_USER=nova_alianca
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

MNSS_ONLINE_DB_URL=jdbc:postgresql://postgres-online:5432/nova_alianca_online
MNSS_ONLINE_DB_USER=nova_alianca
MNSS_ONLINE_DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ============================================================
# RabbitMQ online
# ============================================================
RABBITMQ_DEFAULT_USER=nova_alianca
RABBITMQ_DEFAULT_PASS=REPLACE_WITH_SECURE_PASSWORD

MNSS_ONLINE_RABBITMQ_HOST=rabbitmq-online
MNSS_ONLINE_RABBITMQ_PORT=5672
MNSS_ONLINE_RABBITMQ_USER=nova_alianca
MNSS_ONLINE_RABBITMQ_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ============================================================
# Redis online
# ============================================================
MNSS_ONLINE_REDIS_HOST=redis-online
MNSS_ONLINE_REDIS_PORT=6379

# ============================================================
# API online
# ============================================================
MNSS_ONLINE_API_PORT=8080

# Mínimo 32 bytes: openssl rand -base64 32
MNSS_ONLINE_JWT_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET
# Mínimo 32 bytes: openssl rand -hex 32
SYNC_MASTER_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET

# ============================================================
# URLs públicas
# ============================================================
SITE_URL=https://padarianovaalianca.com.br
API_URL=https://api.padarianovaalianca.com.br
ADMIN_URL=https://admin.padarianovaalianca.com.br

# ============================================================
# Sync local <-> online
# ============================================================
MNSS_DEFAULT_STORE_ID=store-001
# Mínimo 32 bytes — use: openssl rand -hex 32
MNSS_STORE_001_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET

# ============================================================
# Pagamentos online
# ============================================================
# Mínimo 32 bytes — use: openssl rand -hex 32
MNSS_PAYMENT_WEBHOOK_SECRET=REPLACE_WITH_MIN_32_BYTE_RANDOM_SECRET

# ============================================================
# WhatsApp
# ============================================================
WHATSAPP_PROVIDER=mock
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_SECURE_TOKEN

# ============================================================
# Spring Security fallback user
# Usado apenas enquanto não houver cadastro online completo.
# ============================================================
SPRING_SECURITY_USER_NAME=online_admin
SPRING_SECURITY_USER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ============================================================
# Backup
# ============================================================
BACKUP_RETENTION_DAYS=15
